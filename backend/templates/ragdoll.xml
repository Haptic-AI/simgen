<mujoco model="ragdoll">
  <option gravity="0 0 -{{gravity}}" timestep="{{timestep}}"/>

  <visual>
    <global offwidth="640" offheight="480"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.05 0.07 0.1" rgb2="0.15 0.18 0.22" width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.15 0.15 0.15" rgb2="0.2 0.2 0.2" width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance="0.1"/>
    <material name="skin" rgba="0.7 0.5 0.4 1" specular="0.2" shininess="0.3"/>
  </asset>

  <default>
    <joint damping="{{damping}}" armature="0.01"/>
    <geom friction="0.7 0.005 0.001" solref="0.01 1"/>
  </default>

  <worldbody>
    <light directional="true" diffuse="0.8 0.8 0.9" specular="0.3 0.3 0.3" pos="0 -2 3" dir="0 1 -1" castshadow="true"/>
    <light directional="true" diffuse="0.3 0.3 0.4" pos="2 2 2" dir="-1 -1 -0.5" castshadow="false"/>

    <geom name="floor" type="plane" size="5 5 0.1" material="grid"/>

    <camera name="main" pos="0 -4 2.5" xyaxes="1 0 0 0 0.45 1" fovy="50"/>

    <!-- Torso -->
    <body name="torso" pos="0 0 {{drop_height}}">
      <freejoint name="root"/>
      <geom type="capsule" fromto="0 0 -0.15 0 0 0.15" size="0.09" rgba="0.3 0.5 0.9 1"/>

      <!-- Head -->
      <body name="head" pos="0 0 0.25">
        <joint name="neck" type="ball" limited="true" range="0 45"/>
        <geom type="sphere" size="0.1" rgba="0.7 0.55 0.45 1"/>
      </body>

      <!-- Right arm -->
      <body name="r_upper_arm" pos="0.15 0 0.1">
        <joint name="r_shoulder" type="ball" limited="true" range="0 120"/>
        <geom type="capsule" fromto="0 0 0 0.25 0 -0.05" size="0.04" rgba="0.3 0.5 0.9 1"/>
        <body name="r_lower_arm" pos="0.25 0 -0.05">
          <joint name="r_elbow" type="hinge" axis="0 1 0" limited="true" range="0 150"/>
          <geom type="capsule" fromto="0 0 0 0.22 0 -0.03" size="0.035" rgba="0.4 0.6 0.9 1"/>
        </body>
      </body>

      <!-- Left arm -->
      <body name="l_upper_arm" pos="-0.15 0 0.1">
        <joint name="l_shoulder" type="ball" limited="true" range="0 120"/>
        <geom type="capsule" fromto="0 0 0 -0.25 0 -0.05" size="0.04" rgba="0.3 0.5 0.9 1"/>
        <body name="l_lower_arm" pos="-0.25 0 -0.05">
          <joint name="l_elbow" type="hinge" axis="0 1 0" limited="true" range="0 150"/>
          <geom type="capsule" fromto="0 0 0 -0.22 0 -0.03" size="0.035" rgba="0.4 0.6 0.9 1"/>
        </body>
      </body>

      <!-- Right leg -->
      <body name="r_upper_leg" pos="0.08 0 -0.2">
        <joint name="r_hip" type="ball" limited="true" range="0 120"/>
        <geom type="capsule" fromto="0 0 0 0.02 0 -0.3" size="0.05" rgba="0.25 0.45 0.85 1"/>
        <body name="r_lower_leg" pos="0.02 0 -0.3">
          <joint name="r_knee" type="hinge" axis="0 1 0" limited="true" range="0 150"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.28" size="0.04" rgba="0.3 0.5 0.9 1"/>
          <body name="r_foot" pos="0 0 -0.28">
            <joint name="r_ankle" type="hinge" axis="0 1 0" limited="true" range="-45 45"/>
            <geom type="box" size="0.04 0.03 0.08" pos="0.04 0 0" rgba="0.4 0.4 0.5 1"/>
          </body>
        </body>
      </body>

      <!-- Left leg -->
      <body name="l_upper_leg" pos="-0.08 0 -0.2">
        <joint name="l_hip" type="ball" limited="true" range="0 120"/>
        <geom type="capsule" fromto="0 0 0 -0.02 0 -0.3" size="0.05" rgba="0.25 0.45 0.85 1"/>
        <body name="l_lower_leg" pos="-0.02 0 -0.3">
          <joint name="l_knee" type="hinge" axis="0 1 0" limited="true" range="0 150"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.28" size="0.04" rgba="0.3 0.5 0.9 1"/>
          <body name="l_foot" pos="0 0 -0.28">
            <joint name="l_ankle" type="hinge" axis="0 1 0" limited="true" range="-45 45"/>
            <geom type="box" size="0.04 0.03 0.08" pos="-0.04 0 0" rgba="0.4 0.4 0.5 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>
